(function () {
    'use strict';

    console.log('[Chronicler 0.58] loaded on', location.href);

    const Utils = {
        async hash(string) {
            const encoder = new TextEncoder();
            const data = encoder.encode(String(string || ''));
            const hashBuffer = await crypto.subtle.digest('SHA-256', data);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            return hashArray.map((b) => b.toString(16).padStart(2, '0')).join('');
        },

        cleanTitle(title) {
            if (!title) return 'Untitled';
            return title
                .replace(/[\\/:*?"<>|]/g, '')
                .replace(/\s+/g, '_')
                .substring(0, 50)
                .replace(/_+$/g, '');
        },

        formatDate() {
            const now = new Date();
            const yyyy = now.getFullYear();
            const mm = String(now.getMonth() + 1).padStart(2, '0');
            const dd = String(now.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        },

        sleep(ms) {
            return new Promise((resolve) => setTimeout(resolve, ms));
        },

        debounce(func, wait) {
            let timeout;
            return function executedFunction(...args) {
                const later = () => {
                    clearTimeout(timeout);
                    func(...args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        },

        normalizeText(element) {
            if (!element) return '';

            const clone = element.cloneNode(true);
            const garbageSelectors = [
                'button',
                '[role="button"]',
                'svg',
                'img',
                'canvas',
                '.copy-button',
                '.read-aloud',
                '.regenerate-button',
                '[aria-label*="Copy"]',
                '[aria-label*="Regenerate"]',
                '[aria-label*="Read aloud"]',
                '[aria-label*="Good response"]',
                '[aria-label*="Bad response"]'
            ];

            clone.querySelectorAll(garbageSelectors.join(',')).forEach((el) => el.remove());

            let text = '';
            const traverse = (node) => {
                if (node.nodeType === Node.TEXT_NODE) {
                    text += node.textContent;
                    return;
                }

                if (node.nodeType !== Node.ELEMENT_NODE) return;

                const tag = node.tagName.toLowerCase();
                const isBlock = ['p', 'div', 'section', 'article', 'br', 'li', 'pre', 'code', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'blockquote'].includes(tag);

                if (tag === 'br') {
                    text += '\n';
                    return;
                }

                if (isBlock && text.length > 0 && !text.endsWith('\n')) {
                    text += '\n';
                }

                if (tag === 'li') text += '- ';
                if (tag === 'pre') text += '```\n';

                node.childNodes.forEach(traverse);

                if (tag === 'pre') {
                    if (!text.endsWith('\n')) text += '\n';
                    text += '```\n';
                    return;
                }

                if (isBlock && !text.endsWith('\n')) {
                    text += '\n';
                }
            };

            traverse(clone);

            return text
                .replace(/\u00a0/g, ' ')
                .replace(/[ \t]+\n/g, '\n')
                .replace(/\n{3,}/g, '\n\n')
                .trim();
        }
    };

    class DB {
        constructor() {
            this.dbName = 'ChatArchive_v47_1';
            this.version = 1;
            this.db = null;
        }

        async init() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open(this.dbName, this.version);
                request.onupgradeneeded = (e) => {
                    const db = e.target.result;
                    if (!db.objectStoreNames.contains('chats')) {
                        db.createObjectStore('chats', { keyPath: 'chatId' });
                    }
                    if (!db.objectStoreNames.contains('messages')) {
                        const msgStore = db.createObjectStore('messages', { keyPath: 'id', autoIncrement: true });
                        msgStore.createIndex('chatId', 'chatId', { unique: false });
                        msgStore.createIndex('dedupKey', 'dedupKey', { unique: true });
                        msgStore.createIndex('chatId_archiveOrder', ['chatId', 'archiveOrder'], { unique: false });
                    }
                };
                request.onsuccess = (e) => {
                    this.db = e.target.result;
                    resolve();
                };
                request.onerror = (e) => reject(e.target.error);
            });
        }

        async getChat(chatId) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction('chats', 'readonly');
                const store = tx.objectStore('chats');
                const req = store.get(chatId);
                req.onsuccess = () => resolve(req.result);
                req.onerror = () => reject(req.error);
            });
        }

        async updateChat(chatId, data) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction('chats', 'readwrite');
                const store = tx.objectStore('chats');
                const getReq = store.get(chatId);
                getReq.onsuccess = () => {
                    const existing = getReq.result || {
                        chatId,
                        title: 'Untitled',
                        lastKnownUrl: '',
                        isArchivingEnabled: false,
                        stats: { msgCount: 0, lastScan: null, lastExport: null }
                    };
                    const updated = {
                        ...existing,
                        ...data,
                        stats: { ...existing.stats, ...(data.stats || {}) }
                    };
                    const putReq = store.put(updated);
                    putReq.onsuccess = () => resolve(updated);
                    putReq.onerror = () => reject(putReq.error);
                };
                getReq.onerror = () => reject(getReq.error);
            });
        }

        async getHighestVariantIndex(chatId, variantGroupId, role) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction('messages', 'readonly');
                const store = tx.objectStore('messages');
                const index = store.index('chatId');
                const req = index.getAll(chatId);
                req.onsuccess = () => {
                    const messages = req.result;
                    let maxIndex = 0;
                    for (const msg of messages) {
                        if (msg.variantGroupId === variantGroupId && msg.role === role && msg.variantIndex > maxIndex) {
                            maxIndex = msg.variantIndex;
                        }
                    }
                    resolve(maxIndex);
                };
                req.onerror = () => reject(req.error);
            });
        }

        async saveMessage(msg) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction(['messages', 'chats'], 'readwrite');
                const msgStore = tx.objectStore('messages');
                const chatStore = tx.objectStore('chats');

                const finalize = (finalMsg) => {
                    const putReq = msgStore.put(finalMsg);
                    putReq.onsuccess = () => {
                        const chatReq = chatStore.get(finalMsg.chatId);
                        chatReq.onsuccess = () => {
                            const chat = chatReq.result || {
                                chatId: finalMsg.chatId,
                                title: 'Untitled',
                                lastKnownUrl: '',
                                isArchivingEnabled: false,
                                stats: { msgCount: 0, lastScan: null, lastExport: null }
                            };
                            const countReq = msgStore.index('chatId').count(finalMsg.chatId);
                            countReq.onsuccess = () => {
                                chat.stats.msgCount = countReq.result;
                                chatStore.put(chat);
                            };
                        };
                        resolve(putReq.result);
                    };
                    putReq.onerror = (e) => {
                        if (e.target.error && e.target.error.name === 'ConstraintError') {
                            e.preventDefault();
                            resolve(null);
                        } else {
                            reject(e.target.error);
                        }
                    };
                };

                if (msg.prevHash !== '__UNKNOWN__') {
                    const unknownDedupKey = `${msg.chatId}:${msg.role}:${msg.textHash}:__UNKNOWN__:${msg.variantIndex}`;
                    const req = msgStore.index('dedupKey').get(unknownDedupKey);
                    req.onsuccess = () => {
                        let finalMsg = msg;
                        if (req.result) finalMsg = { ...req.result, ...msg, id: req.result.id };
                        finalize(finalMsg);
                    };
                    req.onerror = () => reject(req.error);
                } else {
                    finalize(msg);
                }
            });
        }

        async getMessages(chatId) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction('messages', 'readonly');
                const index = tx.objectStore('messages').index('chatId_archiveOrder');
                const range = IDBKeyRange.bound([chatId, -Infinity], [chatId, Infinity]);
                const req = index.getAll(range);
                req.onsuccess = () => resolve(req.result);
                req.onerror = () => reject(req.error);
            });
        }

        async getMinMaxOrder(chatId) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction('messages', 'readonly');
                const index = tx.objectStore('messages').index('chatId_archiveOrder');
                const range = IDBKeyRange.bound([chatId, -Infinity], [chatId, Infinity]);
                const minReq = index.openCursor(range, 'next');
                const maxReq = index.openCursor(range, 'prev');
                let min = null;
                let max = null;
                minReq.onsuccess = (e) => {
                    if (e.target.result) min = e.target.result.value.archiveOrder;
                };
                maxReq.onsuccess = (e) => {
                    if (e.target.result) max = e.target.result.value.archiveOrder;
                };
                tx.oncomplete = () => resolve({ min, max });
                tx.onerror = () => reject(tx.error);
            });
        }

        async migrateChatId(oldId, newId) {
            if (!oldId || !newId || oldId === newId) return;
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction(['messages', 'chats'], 'readwrite');
                const msgStore = tx.objectStore('messages');
                const chatStore = tx.objectStore('chats');

                const oldChatReq = chatStore.get(oldId);
                oldChatReq.onsuccess = () => {
                    if (oldChatReq.result) {
                        const oldChat = oldChatReq.result;
                        const newChatReq = chatStore.get(newId);
                        newChatReq.onsuccess = () => {
                            if (!newChatReq.result) {
                                oldChat.chatId = newId;
                                chatStore.put(oldChat);
                            }
                            chatStore.delete(oldId);
                        };
                    }
                };

                const index = msgStore.index('chatId');
                const cursorReq = index.openCursor(oldId);
                cursorReq.onsuccess = (e) => {
                    const cursor = e.target.result;
                    if (cursor) {
                        const msg = cursor.value;
                        msg.chatId = newId;
                        msg.dedupKey = `${newId}:${msg.role}:${msg.textHash}:${msg.prevHash}:${msg.variantIndex}`;
                        const updateReq = cursor.update(msg);
                        updateReq.onerror = (err) => {
                            if (err.target.error && err.target.error.name === 'ConstraintError') {
                                err.preventDefault();
                                cursor.delete();
                            }
                        };
                        cursor.continue();
                    }
                };

                tx.oncomplete = () => resolve();
                tx.onerror = (e) => reject(e.target.error);
            });
        }

        async deleteChat(chatId) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction(['messages', 'chats'], 'readwrite');
                const chatStore = tx.objectStore('chats');
                const msgStore = tx.objectStore('messages');
                chatStore.delete(chatId);
                const index = msgStore.index('chatId');
                const req = index.openCursor(chatId);
                req.onsuccess = (e) => {
                    const cursor = e.target.result;
                    if (cursor) {
                        cursor.delete();
                        cursor.continue();
                    }
                };
                tx.oncomplete = () => resolve();
                tx.onerror = () => reject(tx.error);
            });
        }

        async clearOldArchives(days) {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction(['chats', 'messages'], 'readwrite');
                const chatStore = tx.objectStore('chats');
                const msgStore = tx.objectStore('messages');
                const cutoff = Date.now() - days * 86400000;
                const chatsReq = chatStore.getAll();
                chatsReq.onsuccess = () => {
                    const chats = chatsReq.result;
                    let pendingChats = chats.length;
                    if (pendingChats === 0) {
                        resolve(0);
                        return;
                    }
                    let deletedCount = 0;
                    chats.forEach((chat) => {
                        const msgReq = msgStore.index('chatId').getAll(chat.chatId);
                        msgReq.onsuccess = () => {
                            const messages = msgReq.result;
                            let maxTimestamp = 0;
                            messages.forEach((m) => {
                                if (m.captureTimestamp > maxTimestamp) maxTimestamp = m.captureTimestamp;
                            });
                            if (maxTimestamp > 0 && maxTimestamp < cutoff) {
                                chatStore.delete(chat.chatId);
                                messages.forEach((m) => msgStore.delete(m.id));
                                deletedCount += 1;
                            }
                            pendingChats -= 1;
                            if (pendingChats === 0) resolve(deletedCount);
                        };
                        msgReq.onerror = () => {
                            pendingChats -= 1;
                            if (pendingChats === 0) resolve(deletedCount);
                        };
                    });
                };
                chatsReq.onerror = () => reject(chatsReq.error);
            });
        }

        async calculateApproximateSize() {
            return new Promise((resolve, reject) => {
                const tx = this.db.transaction('messages', 'readonly');
                const store = tx.objectStore('messages');
                const req = store.openCursor();
                let totalBytes = 0;
                req.onsuccess = (e) => {
                    const cursor = e.target.result;
                    if (cursor) {
                        const msg = cursor.value;
                        totalBytes += (msg.text ? msg.text.length : 0) * 2;
                        totalBytes += (msg.role ? msg.role.length : 0) * 2;
                        totalBytes += 160;
                        cursor.continue();
                    } else {
                        resolve(totalBytes);
                    }
                };
                req.onerror = () => reject(req.error);
            });
        }

        canRead() {
            try {
                if (!this.db) return false;
                this.db.transaction(['messages', 'chats'], 'readonly');
                return true;
            } catch {
                return false;
            }
        }
    }

    const appDb = new DB();

    class Engine {
        constructor(db) {
            this.db = db;
            this.adapter = null;
            this.currentChatId = null;
            this.observer = null;
            this.isArchiving = false;
            this.isScannerActive = false;
            this.hasFatalDbError = false;
            this.pendingEntry = null;
            this.quietTimeout = null;
            this.lastKnownUserHash = '__ROOT__';
            this.hasConfirmedUserInCurrentPass = false;
            this.onStateChange = () => {};
            this.onStatsUpdate = () => {};
            this.currentMaxOrder = 0;
            this.currentMinOrder = Infinity;
            this.pendingVariantHint = null;
            this.abortDeepScan = false;
        }

        resetCurrentChatState() {
            this.pendingEntry = null;
            clearTimeout(this.quietTimeout);
            this.quietTimeout = null;
            this.lastKnownUserHash = '__ROOT__';
            this.hasConfirmedUserInCurrentPass = false;
            this.currentMaxOrder = 0;
            this.currentMinOrder = Infinity;
            this.pendingVariantHint = null;
            this.onStatsUpdate(0);
        }

        setAdapter(adapterName) {
            let SelectedAdapter = PlatformAdapter;
            if (adapterName === 'Auto') {
                if (location.hostname.includes('chatgpt.com')) SelectedAdapter = ChatGPTAdapter;
                else if (location.hostname.includes('gemini.google.com')) SelectedAdapter = GeminiAdapter;
            } else if (adapterName === 'ChatGPT') {
                SelectedAdapter = ChatGPTAdapter;
            } else if (adapterName === 'Gemini') {
                SelectedAdapter = GeminiAdapter;
            }
            this.adapter = new SelectedAdapter();
            return this.adapter.constructor.name;
        }

        async updateCurrentChatId() {
            if (this.hasFatalDbError) return;
            let id = this.adapter.getChatId();
            if (!id) {
                let firstUserText = null;
                const msgs = this.adapter.extractL1();
                const userMsg = msgs.find((m) => m.role === 'USER');
                if (userMsg) firstUserText = userMsg.text;
                const rawTempId = this.adapter.getTempId(firstUserText);
                id = await Utils.hash(rawTempId);
            }

            if (this.currentChatId && this.currentChatId !== id) {
                if (this.currentChatId.length === 64 && id.length !== 64) {
                    await this.db.migrateChatId(this.currentChatId, id);
                }
            }

            this.currentChatId = id;
            this.lastKnownUserHash = '__ROOT__';
            this.hasConfirmedUserInCurrentPass = false;

            const { min, max } = await this.db.getMinMaxOrder(this.currentChatId);
            this.currentMinOrder = min !== null ? min : Infinity;
            this.currentMaxOrder = max !== null ? max : 0;

            const chat = await this.db.getChat(this.currentChatId);
            const isEnabledForChat = chat ? (chat.isArchivingEnabled ?? false) : false;
            this.isArchiving = isEnabledForChat;

            await this.db.updateChat(this.currentChatId, {
                title: document.title,
                lastKnownUrl: location.href,
                isArchivingEnabled: this.isArchiving
            });

            await this.updateStats();
            if (this.isArchiving) {
                this.startObserverOnly();
            } else {
                await this.stopObserverOnly();
            }
        }

        async updateStats() {
            if (!this.currentChatId) {
                this.onStatsUpdate(0);
                return;
            }
            const chat = await this.db.getChat(this.currentChatId);
            this.onStatsUpdate(chat && chat.stats ? chat.stats.msgCount : 0);
        }

        async setArchiveForCurrentChat(enabled) {
            if (this.hasFatalDbError) return;
            if (!this.adapter.healthCheck()) {
                this.onStateChange('ADAPTER MISMATCH');
                return;
            }
            this.isArchiving = enabled;
            if (this.currentChatId) {
                await this.db.updateChat(this.currentChatId, { isArchivingEnabled: enabled });
            }
            if (enabled) this.startObserverOnly();
            else await this.stopObserverOnly();
        }

        startObserverOnly() {
            if (this.hasFatalDbError) return;
            if (!this.adapter.healthCheck()) {
                this.onStateChange('ADAPTER MISMATCH');
                return;
            }
            this.onStateChange('ARCHIVING');
            this.setupObserver();
            this.runFullExtraction();
        }

        async stopObserverOnly({ flushPending = true, preserveState = false } = {}) {
            if (!preserveState) this.onStateChange('IDLE');
            if (this.observer) {
                this.observer.disconnect();
                this.observer = null;
            }
            if (flushPending) await this.flushPendingEntry('stop');
        }

        setupObserver() {
            if (this.observer) this.observer.disconnect();
            const target = this.adapter.getObserverTarget();
            if (!target) return;
            this.observer = new MutationObserver((mutations) => {
                this.handleMutations(mutations);
            });
            this.observer.observe(target, { childList: true, subtree: true, characterData: true });
        }

        async handleMutations(mutations) {
            if (this.hasFatalDbError || !this.isArchiving || this.isScannerActive) return;

            const hasChildList = mutations.some((m) => m.type === 'childList' && ((m.addedNodes && m.addedNodes.length) || (m.removedNodes && m.removedNodes.length)));
            const l3Updates = this.adapter.extractL3FromMutations(mutations);
            const unique = new Map();
            for (const update of l3Updates) {
                if (!update || !update.text) continue;
                unique.set(`${update.role}:${update.nodeSignature}:${update.text.length}`, update);
            }
            for (const update of unique.values()) {
                await this.processMessage(update, 'AUTOSAVE');
            }

            if (hasChildList) {
                this.debouncedFullExtraction();
            } else if (unique.size === 0) {
                this.debouncedFullExtraction();
            }
        }

        debouncedFullExtraction = Utils.debounce(() => {
            this.runFullExtraction();
        }, 700);

        async runFullExtraction(source = 'AUTOSAVE') {
            if (this.hasFatalDbError || !this.adapter.healthCheck()) return;
            let msgs = this.adapter.extractL1();
            if (msgs.length === 0) msgs = this.adapter.extractL2();
            this.lastKnownUserHash = '__ROOT__';
            this.hasConfirmedUserInCurrentPass = false;
            for (const msg of msgs) {
                await this.processMessage(msg, source);
            }
        }

        async processMessage(msgData, source, forcedArchiveOrder = null, lockedChatId = null) {
            if (this.hasFatalDbError) return { inserted: false, archiveOrder: forcedArchiveOrder };
            if (!msgData || !msgData.text) return { inserted: false, archiveOrder: forcedArchiveOrder };
            
            const targetChatId = lockedChatId || this.currentChatId;

            const textHash = await Utils.hash(msgData.text);
            let prevHash = '__UNKNOWN__';

            if (msgData.role === 'USER') {
                prevHash = this.lastKnownUserHash;
                this.lastKnownUserHash = textHash;
                this.hasConfirmedUserInCurrentPass = true;
                await this.flushPendingEntry('user_message');
            } else if (msgData.role === 'ASSISTANT') {
                prevHash = this.hasConfirmedUserInCurrentPass ? this.lastKnownUserHash : '__UNKNOWN__';
            }

            const variantGroupId = prevHash;
            let variantIndex = 1;

            if (msgData.role === 'ASSISTANT' && source !== 'DEEPSCAN' && this.pendingEntry && this.pendingEntry.nodeSignature === msgData.nodeSignature) {
                return this.handleStreamingGuard({ 
                    ...this.pendingEntry, 
                    text: msgData.text, 
                    textHash, 
                    dedupKey: `${targetChatId}:${msgData.role}:${textHash}:${prevHash}:${this.pendingEntry.variantIndex}`
                });
            }

            if (this.adapter.getCapabilities().supportsVariants && variantGroupId !== '__UNKNOWN__') {
                const maxIdx = await this.db.getHighestVariantIndex(targetChatId, variantGroupId, msgData.role);
                if (maxIdx > 0) {
                    const messagesForCtx = (await this.db.getMessages(targetChatId)).filter((m) => m.variantGroupId === variantGroupId && m.role === msgData.role);
                    const exactMatch = messagesForCtx.find((m) => m.textHash === textHash);
                    if (exactMatch) {
                        variantIndex = exactMatch.variantIndex;
                    } else if (this.pendingVariantHint) {
                        variantIndex = maxIdx + 1;
                        this.pendingVariantHint = null;
                    } else {
                        return { inserted: false, archiveOrder: forcedArchiveOrder ?? this.currentMaxOrder };
                    }
                }
            }

            const record = {
                chatId: targetChatId,
                role: msgData.role,
                text: msgData.text,
                textHash,
                prevHash,
                variantGroupId,
                variantIndex,
                dedupKey: `${targetChatId}:${msgData.role}:${textHash}:${prevHash}:${variantIndex}`,
                captureTimestamp: Date.now(),
                sourceType: source,
                nodeSignature: msgData.nodeSignature,
                archiveOrder: forcedArchiveOrder
            };

            if (msgData.role === 'ASSISTANT' && source !== 'DEEPSCAN') {
                return this.handleStreamingGuard(record);
            }
            return this.writeToDB(record);
        }

        async handleStreamingGuard(record) {
            if (!this.adapter.getCapabilities().supportsReliableStreamingDetection) {
                return this.writeToDB(record);
            }
            if (this.pendingEntry && this.pendingEntry.nodeSignature !== record.nodeSignature) {
                await this.flushPendingEntry('new_node');
            }
            this.pendingEntry = record;
            clearTimeout(this.quietTimeout);
            this.quietTimeout = setTimeout(() => {
                this.flushPendingEntry('quiet_period');
            }, 1200);
            return { inserted: false, archiveOrder: record.archiveOrder };
        }

        async flushPendingEntry(reason) {
            if (!this.pendingEntry) return;
            const pending = this.pendingEntry;
            this.pendingEntry = null;
            clearTimeout(this.quietTimeout);
            this.quietTimeout = null;
            await this.writeToDB(pending);
        }

        async writeToDB(record) {
            if (record.archiveOrder === null || record.archiveOrder === undefined) {
                this.currentMaxOrder += 100;
                record.archiveOrder = this.currentMaxOrder;
            }
            try {
                const result = await this.db.saveMessage(record);
                if (result) {
                    await this.db.updateChat(record.chatId, { title: document.title, lastKnownUrl: location.href });
                    if (record.chatId === this.currentChatId) {
                        await this.updateStats();
                        this.onStateChange('SAVED');
                        setTimeout(() => {
                            if (this.isArchiving && !this.isScannerActive && !this.hasFatalDbError && !this.abortDeepScan) {
                                this.onStateChange('ARCHIVING');
                            }
                        }, 1500);
                    }
                    return { inserted: true, archiveOrder: record.archiveOrder };
                }
                return { inserted: false, archiveOrder: record.archiveOrder };
            } catch (e) {
                this.hasFatalDbError = true;
                this.onStateChange('DB ERROR', `Failed to write message: ${e.message}`);
                this.isArchiving = false;
                await this.stopObserverOnly({ flushPending: false, preserveState: true });
                return { inserted: false, archiveOrder: record.archiveOrder };
            }
        }

        async performDeepScan() {
            if (this.hasFatalDbError) return;
            if (this.isScannerActive) return;
            if (this.pendingEntry) {
                console.warn('[Chronicler] cannot deep scan while assistant is streaming');
                return;
            }

            const container = this.adapter.getScrollContainer();
            if (!container) return;

            const originalScroll = container.scrollTop;
            const originalPath = location.pathname;
            const originalChatId = this.currentChatId;
            const wasArchiving = this.isArchiving;
            this.isScannerActive = true;
            this.isArchiving = false;
            this.abortDeepScan = false;
            this.onStateChange('SCANNING');
            if (this.observer) this.observer.disconnect();

            let iterationsWithoutInserts = 0;
            const startTime = Date.now();
            let liveCount = 0;

            try {
                while (true) {
                    if (Date.now() - startTime > 5 * 60 * 1000) break;
                    if (location.pathname !== originalPath) break;
                    if (this.currentChatId !== originalChatId) break;

                    let msgs = this.adapter.extractL1();
                    if (msgs.length === 0) msgs = this.adapter.extractL2();
                    const n = msgs.length;
                    const insertedOrders = [];

                    this.lastKnownUserHash = '__ROOT__';
                    this.hasConfirmedUserInCurrentPass = false;

                    if (!Number.isFinite(this.currentMinOrder)) {
                        for (let i = 0; i < n; i += 1) {
                            if (location.pathname !== originalPath || this.abortDeepScan) {
                                iterationsWithoutInserts = 999;
                                break;
                            }
                            const order = (i + 1) * 100;
                            const result = await this.processMessage(msgs[i], 'DEEPSCAN', order, originalChatId);
                            if (result && result.inserted) insertedOrders.push(result.archiveOrder);
                        }
                        if (insertedOrders.length > 0) {
                            this.currentMinOrder = Math.min(...insertedOrders);
                            this.currentMaxOrder = Math.max(...insertedOrders);
                            iterationsWithoutInserts = 0;
                            liveCount += insertedOrders.length;
                            this.onStateChange(`SCANNING [${liveCount}]`);
                        } else {
                            iterationsWithoutInserts += 1;
                        }
                    } else {
                        const baseOrder = this.currentMinOrder - n * 100;
                        for (let i = 0; i < n; i += 1) {
                            if (location.pathname !== originalPath || this.abortDeepScan) {
                                iterationsWithoutInserts = 999;
                                break;
                            }
                            const order = baseOrder + i * 100;
                            const result = await this.processMessage(msgs[i], 'DEEPSCAN', order, originalChatId);
                            if (result && result.inserted) insertedOrders.push(result.archiveOrder);
                        }
                        if (insertedOrders.length > 0) {
                            this.currentMinOrder = Math.min(this.currentMinOrder, ...insertedOrders);
                            iterationsWithoutInserts = 0;
                            liveCount += insertedOrders.length;
                            this.onStateChange(`SCANNING [${liveCount}]`);
                        } else {
                            iterationsWithoutInserts += 1;
                        }
                    }

                    if (iterationsWithoutInserts >= 15) {
                        console.warn('[Chronicler] DeepScan exceeded 15 dry iterations. Breaking to prevent infinite freeze.');
                        break;
                    }

                    if (container.scrollTop === 0) {
                        container.scrollTop = 10;
                        await Utils.sleep(50);
                        container.scrollTop = 0;
                        await Utils.sleep(3000);
                        if (container.scrollTop === 0) break;
                    }

                    container.scrollTop -= 1500;
                    await Utils.sleep(1200);
                }
            } finally {
                container.scrollTop = originalScroll;
                this.isScannerActive = false;
                if (this.abortDeepScan || location.pathname !== originalPath || this.currentChatId !== originalChatId) {
                    console.warn('[Chronicler] DeepScan aborted cleanly without re-arming observer.');
                } else {
                    this.isArchiving = wasArchiving;
                    if (!this.hasFatalDbError) {
                        if (wasArchiving) {
                            this.setupObserver();
                            this.onStateChange('ARCHIVING');
                        } else {
                            this.onStateChange('IDLE');
                        }
                    }
                }
                await this.updateStats();
            }
        }
    }

    class RouteWatcher {
        constructor(engine) {
            this.engine = engine;
            this.lastUrl = null;
            this.checkInterval = null;
        }

        start() {
            document.body.addEventListener('click', (e) => {
                const text = e.target.innerText || e.target.getAttribute('aria-label') || '';
                const lowerText = text.toLowerCase();
                if (lowerText.includes('regenerate') || lowerText.includes('edit') || lowerText.includes('modify')) {
                    this.engine.pendingVariantHint = true;
                    setTimeout(() => {
                        this.engine.pendingVariantHint = null;
                    }, 5000);
                }
            }, true);

            const pushState = history.pushState;
            history.pushState = function () {
                pushState.apply(history, arguments);
                window.dispatchEvent(new Event('locationchange'));
            };

            const replaceState = history.replaceState;
            history.replaceState = function () {
                replaceState.apply(history, arguments);
                window.dispatchEvent(new Event('locationchange'));
            };

            window.addEventListener('popstate', () => window.dispatchEvent(new Event('locationchange')));
            window.addEventListener('locationchange', () => this.handleRoute());

            this.checkInterval = setInterval(() => {
                if (this.lastUrl !== location.href) this.handleRoute();
            }, 2000);

            this.handleRoute();
        }

        async handleRoute() {
            const newUrl = location.href;
            if (this.lastUrl === newUrl) return;
            this.lastUrl = newUrl;
            if (this.engine.isScannerActive) {
                this.engine.abortDeepScan = true;
            }
            await this.engine.flushPendingEntry('route_change');
            setTimeout(() => {
                this.engine.updateCurrentChatId();
            }, 1000);
        }
    }

