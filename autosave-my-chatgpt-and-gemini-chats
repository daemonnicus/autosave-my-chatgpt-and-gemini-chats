                    make('strong', { id: 'chron-count', text: '0', style: { color: '#f9e2af' } }),
                    make('span', { id: 'chron-size', text: ' (0 MB)', style: { color: '#a6adc8', fontSize: '11px', marginLeft: '5px' } })
                ])
