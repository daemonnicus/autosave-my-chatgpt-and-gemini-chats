                make('button', { id: 'chron-export-md', text: 'Export .md', title: 'Экспорт в Markdown', style: buttonStyle('#a6e3a1') }),
                make('button', { id: 'chron-export-json', text: 'Export .json', title: 'Экспорт в JSON формате', style: buttonStyle('#a6e3a1') }),
                make('button', { id: 'chron-export-parts', text: 'Parts', title: 'Экспорт длинного чата по частям', style: { ...buttonStyle('#a6e3a1'), flex: '0.8' } })
