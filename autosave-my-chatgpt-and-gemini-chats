        bindEvents() {
            this.container.querySelector('#chron-header').addEventListener('click', (e) => {
                if (e.target.id === 'chron-engine-select') return;
                this.isCollapsed = !this.isCollapsed;
                localStorage.setItem('ChroniclerCollapsed', String(this.isCollapsed));
                this.container.querySelector('#chron-body').style.display = this.isCollapsed ? 'none' : 'block';
                this.container.querySelector('#chron-collapse').textContent = this.isCollapsed ? '[+]' : '[-]';
            });

            this.container.querySelector('#chron-engine-select').addEventListener('change', (e) => {
                const val = e.target.value;
                localStorage.setItem(`ChroniclerEngine_${location.hostname}`, val);
                this.engine.flushPendingEntry('adapter_change').then(async () => {
                    const actualName = this.engine.setAdapter(val);
                    this.updateEngineLabel(val, actualName);
                    await this.engine.updateCurrentChatId();
                });
            });

            this.container.querySelector('#chron-toggle').addEventListener('change', (e) => {
                this.engine.setArchiveForCurrentChat(e.target.checked);
            });

            this.container.querySelector('#chron-deep-scan').addEventListener('click', async () => {
                if (this.engine.pendingEntry) {
                    this.showError('Wait for assistant to finish before scanning.');
                    return;
                }
                if (!this.engine.adapter.getCapabilities().supportsDeepScan) {
                    this.showError('Deep Scan not supported on this platform.');
                    return;
                }
                const container = this.engine.adapter.getScrollContainer();
                if (!container) {
                    this.showError('Deep Scan failed: scroll container not found.');
                    return;
                }
                await this.engine.performDeepScan();
                this.updateDbSize();
            });

            this.container.querySelector('#chron-export').addEventListener('click', () => this.performExport());
            this.container.querySelector('#chron-export-md').addEventListener('click', () => this.performMarkdownExport());
            this.container.querySelector('#chron-export-json').addEventListener('click', () => this.performJsonExport());
            this.container.querySelector('#chron-export-parts').addEventListener('click', () => this.performPartExport());
            this.container.querySelector('#chron-copy-all').addEventListener('click', (e) => this.performCopyAll(e.target));

            this.container.querySelector('#chron-del-chat').addEventListener('click', async () => {
                if (!this.engine.currentChatId) return;
                if (!window.confirm('Удалить архив текущего чата?')) return;
                if (this.engine.isArchiving) await this.engine.setArchiveForCurrentChat(false);
                this.container.querySelector('#chron-toggle').checked = false;
                await this.engine.flushPendingEntry('delete_chat');
                const deletedId = this.engine.currentChatId;
                await appDb.deleteChat(deletedId);
                this.engine.resetCurrentChatState();
                await this.engine.updateCurrentChatId();
                this.updateDbSize();
            });

            this.container.querySelector('#chron-del-old').addEventListener('click', async () => {
                await this.engine.flushPendingEntry('delete_old');
                if (!window.confirm('Удалить архивы старше 30 дней (по дате последнего сообщения)?')) return;
                const deleted = await appDb.clearOldArchives(30);
                if (this.engine.currentChatId) {
                    const currentMessages = await appDb.getMessages(this.engine.currentChatId);
                    if (currentMessages.length === 0) {
                        if (this.engine.isArchiving) await this.engine.setArchiveForCurrentChat(false);
                        this.container.querySelector('#chron-toggle').checked = false;
                        this.engine.resetCurrentChatState();
                    }
                    await this.engine.updateCurrentChatId();
                }
                this.updateDbSize();
                this.showError(`Удалено архивов: ${deleted}`);
            });
        }

        updateEngineLabel(override, actual) {
            const label = override === 'Auto' ? `Auto (${actual.replace('Adapter', '')})` : override;
            this.container.querySelector('#chron-engine-label').textContent = label;
        }

        updateState(state, errorReason = null) {
            this.state = state;
            const statusEl = this.container.querySelector('#chron-status');
            const toggle = this.container.querySelector('#chron-toggle');
            const scanBtn = this.container.querySelector('#chron-deep-scan');
            const exportBtn = this.container.querySelector('#chron-export');
            const exportMdBtn = this.container.querySelector('#chron-export-md');
            const exportJsonBtn = this.container.querySelector('#chron-export-json');
            const exportPartsBtn = this.container.querySelector('#chron-export-parts');
            const copyAllBtn = this.container.querySelector('#chron-copy-all');
            const delChatBtn = this.container.querySelector('#chron-del-chat');
            const delOldBtn = this.container.querySelector('#chron-del-old');
            const engineSelect = this.container.querySelector('#chron-engine-select');
            const header = this.container.querySelector('#chron-header');

            statusEl.textContent = state;
            header.style.background = '#181825';
            this.hideError();

            const noChatOrEmpty = !this.engine.currentChatId || this.currentMsgCount === 0;
            const setActionState = (disabled) => {
                scanBtn.disabled = disabled || state.startsWith('SCANNING');
                exportBtn.disabled = disabled || noChatOrEmpty;
                exportMdBtn.disabled = disabled || noChatOrEmpty;
                exportJsonBtn.disabled = disabled || noChatOrEmpty;
                exportPartsBtn.disabled = disabled || noChatOrEmpty;
                copyAllBtn.disabled = disabled || noChatOrEmpty;
                delChatBtn.disabled = disabled || noChatOrEmpty;
                delOldBtn.disabled = disabled;
            };

            if (state.startsWith('SCANNING')) {
                statusEl.style.color = '#f9e2af';
                toggle.disabled = true;
                setActionState(true);
                engineSelect.disabled = true;
                return;
            }

            if (state === 'ADAPTER MISMATCH') {
                statusEl.style.color = '#fab387';
                toggle.checked = false;
                toggle.disabled = false;
                scanBtn.disabled = true;
                const canRead = this.engine.db.canRead();
                exportBtn.disabled = !canRead || noChatOrEmpty;
                exportMdBtn.disabled = !canRead || noChatOrEmpty;
                exportJsonBtn.disabled = !canRead || noChatOrEmpty;
                exportPartsBtn.disabled = !canRead || noChatOrEmpty;
                copyAllBtn.disabled = !canRead || noChatOrEmpty;
                delChatBtn.disabled = !canRead || noChatOrEmpty;
                delOldBtn.disabled = !canRead;
                engineSelect.disabled = false;
                this.showError('Health check failed. Autosave blocked.');
                return;
            }

            if (state === 'DB ERROR') {
                header.style.background = '#721c24';
                statusEl.style.color = '#f38ba8';
                toggle.disabled = true;
                const canRead = this.engine.db.canRead();
                if (canRead) {
                    exportBtn.disabled = noChatOrEmpty;
                    exportMdBtn.disabled = noChatOrEmpty;
                    exportJsonBtn.disabled = noChatOrEmpty;
                    exportPartsBtn.disabled = noChatOrEmpty;
                    copyAllBtn.disabled = noChatOrEmpty;
                    delChatBtn.disabled = noChatOrEmpty;
                    delOldBtn.disabled = false;
                    scanBtn.disabled = true;
                } else {
                    setActionState(true);
                }
                engineSelect.disabled = true;
                if (errorReason) this.showError(errorReason);
                return;
            }

            if (state === 'ARCHIVING') {
                statusEl.style.color = '#a6e3a1';
                toggle.checked = true;
                toggle.disabled = false;
                setActionState(false);
                engineSelect.disabled = false;
                return;
            }

            if (state === 'SAVED') {
                statusEl.style.color = '#89dceb';
                toggle.checked = !!this.engine.isArchiving;
                toggle.disabled = false;
                setActionState(false);
                engineSelect.disabled = false;
                return;
            }

            statusEl.style.color = '#89b4fa';
            toggle.checked = false;
            toggle.disabled = false;
            setActionState(false);
            engineSelect.disabled = false;
        }

        updateStats(count) {
            this.currentMsgCount = count;
            this.container.querySelector('#chron-count').textContent = String(count);
            this.updateState(this.state);
            this.updateDbSize();
        }

        async updateDbSize() {
            try {
                const bytes = await appDb.calculateApproximateSize();
                const mb = (bytes / (1024 * 1024)).toFixed(2);
                const sizeEl = this.container.querySelector('#chron-size');
                if (sizeEl) sizeEl.textContent = ` (${mb} MB)`;
            } catch (e) {
                console.error(e);
            }
        }

        showError(msg) {
            const errEl = this.container.querySelector('#chron-error-msg');
            errEl.textContent = msg;
            errEl.style.display = 'block';
            clearTimeout(this.errorTimer);
            this.errorTimer = setTimeout(() => this.hideError(), 4000);
        }

        hideError() {
            const errEl = this.container.querySelector('#chron-error-msg');
            errEl.style.display = 'none';
        }
    }

    function buildTextExportContent(chat, messages) {
        const variantMap = {};
        messages.forEach((m) => {
            if (!variantMap[m.variantGroupId]) variantMap[m.variantGroupId] = new Set();
            variantMap[m.variantGroupId].add(m.variantIndex);
        });

        let content = '======================================================================\n';
        content += `TITLE: ${chat ? chat.title : document.title}\n`;
        content += `URL: ${chat ? chat.lastKnownUrl : location.href}\n`;
        content += `EXPORT DATE: ${new Date().toLocaleString()}\n`;
        content += `MESSAGE COUNT: ${messages.length}\n`;
        content += '======================================================================\n\n';

        for (const msg of messages) {
            const hasVariants = msg.variantGroupId !== '__UNKNOWN__' && variantMap[msg.variantGroupId] && variantMap[msg.variantGroupId].size > 1;
            const versionStr = hasVariants ? ` | V${msg.variantIndex}` : '';
            content += `[${msg.role}]${versionStr}\n`;
            content += `${msg.text}\n\n`;
            content += '----------------------------------------------------------------------\n\n';
        }
        return content;
    }

    async function performExport(engine, ui) {
        await engine.flushPendingEntry('export');
        if (!engine.currentChatId) {
            ui.showError('No chat ID detected.');
            return;
        }
        const chat = await appDb.getChat(engine.currentChatId);
        const messages = await appDb.getMessages(engine.currentChatId);
        if (messages.length === 0) {
            ui.showError('Archive is empty. Enable archiving or run Deep Scan.');
            return;
        }
        messages.sort((a, b) => a.archiveOrder - b.archiveOrder);
        const safeTitle = Utils.cleanTitle(chat ? chat.title : document.title);
        const shortId = engine.currentChatId.substring(0, 6);
        const dateStr = Utils.formatDate();
        const platform = location.hostname.includes('chatgpt.com') ? 'ChatGPT' : 'Gemini';
        const filename = `Archive_${platform}_${safeTitle}_${dateStr}_${shortId}.txt`;
        downloadBlob(new Blob([buildTextExportContent(chat, messages)], { type: 'text/plain;charset=utf-8' }), filename);
    }

    async function performMarkdownExport(engine, ui) {
        await engine.flushPendingEntry('export_md');
        if (!engine.currentChatId) {
            ui.showError('No chat ID detected.');
            return;
        }
        const chat = await appDb.getChat(engine.currentChatId);
        const messages = await appDb.getMessages(engine.currentChatId);
        if (messages.length === 0) {
            ui.showError('Archive is empty. Enable archiving or run Deep Scan.');
            return;
        }
        messages.sort((a, b) => a.archiveOrder - b.archiveOrder);
        const safeTitle = Utils.cleanTitle(chat ? chat.title : document.title);
        const shortId = engine.currentChatId.substring(0, 6);
        const dateStr = Utils.formatDate();
        const platform = location.hostname.includes('chatgpt.com') ? 'ChatGPT' : 'Gemini';
        const filename = `Archive_${platform}_${safeTitle}_${dateStr}_${shortId}.md`;
        let content = `# ${chat ? chat.title : document.title}\n\n`;
        content += `**URL:** ${chat ? chat.lastKnownUrl : location.href}\n`;
        content += `**Export Date:** ${new Date().toLocaleString()}\n`;
        content += `**Message Count:** ${messages.length}\n\n`;
        for (const msg of messages) {
            const d = new Date(msg.captureTimestamp);
            const hh = String(d.getHours()).padStart(2, '0');
            const mm = String(d.getMinutes()).padStart(2, '0');
            content += `**[${msg.role}]** (${hh}:${mm}):\n`;
            content += `${msg.text}\n\n`;
        }
        downloadBlob(new Blob([content], { type: 'text/markdown;charset=utf-8' }), filename);
    }

    async function performJsonExport(engine, ui) {
        await engine.flushPendingEntry('export_json');
        if (!engine.currentChatId) {
            ui.showError('No chat ID detected.');
            return;
        }
        const chat = await appDb.getChat(engine.currentChatId);
        const messages = await appDb.getMessages(engine.currentChatId);
        if (messages.length === 0) {
            ui.showError('Archive is empty. Enable archiving or run Deep Scan.');
            return;
        }
        messages.sort((a, b) => a.archiveOrder - b.archiveOrder);
        const platform = location.hostname.includes('chatgpt.com') ? 'ChatGPT' : 'Gemini';
        const schema = {
            version: '0.58',
            platform,
            chatId: engine.currentChatId,
            title: chat ? chat.title : document.title,
            url: chat ? chat.lastKnownUrl : location.href,
            exportedAt: new Date().toISOString(),
            messageCount: messages.length,
            messages: messages.map((m) => ({
                role: m.role,
                text: m.text,
                timestamp: new Date(m.captureTimestamp).toISOString(),
                archiveOrder: m.archiveOrder,
                variantIndex: m.variantIndex
            }))
        };
        const safeTitle = Utils.cleanTitle(chat ? chat.title : document.title);
        const shortId = engine.currentChatId.substring(0, 6);
        const dateStr = Utils.formatDate();
        const filename = `Archive_${platform}_${safeTitle}_${dateStr}_${shortId}.json`;
        downloadBlob(new Blob([JSON.stringify(schema, null, 2)], { type: 'application/json;charset=utf-8' }), filename);
    }

    async function performPartExport(engine, ui) {
        await engine.flushPendingEntry('export_parts');
        if (!engine.currentChatId) {
            ui.showError('No chat ID detected.');
            return;
        }
        const chat = await appDb.getChat(engine.currentChatId);
        const messages = await appDb.getMessages(engine.currentChatId);
        if (messages.length === 0) {
            ui.showError('Archive is empty. Enable archiving or run Deep Scan.');
            return;
        }
        messages.sort((a, b) => a.archiveOrder - b.archiveOrder);
        const safeTitle = Utils.cleanTitle(chat ? chat.title : document.title);
        const shortId = engine.currentChatId.substring(0, 6);
        const dateStr = Utils.formatDate();
        const platform = location.hostname.includes('chatgpt.com') ? 'ChatGPT' : 'Gemini';
        const CHUNK_SIZE = 200;
        const totalChunks = Math.ceil(messages.length / CHUNK_SIZE);
        for (let i = 0; i < totalChunks; i += 1) {
            const partNum = i + 1;
            const chunk = messages.slice(i * CHUNK_SIZE, (i + 1) * CHUNK_SIZE);
            const filename = `Archive_${platform}_${safeTitle}_${dateStr}_${shortId}_part${partNum}.txt`;
            const chunkChat = { ...(chat || {}), title: `${chat ? chat.title : document.title} (Part ${partNum}/${totalChunks})` };
            downloadBlob(new Blob([buildTextExportContent(chunkChat, chunk)], { type: 'text/plain;charset=utf-8' }), filename);
            await Utils.sleep(300);
        }
    }

    async function performCopyAll(engine, ui, buttonEl) {
        await engine.flushPendingEntry('copy_all');
        if (!engine.currentChatId) {
            ui.showError('No chat ID detected.');
            return;
        }
        const chat = await appDb.getChat(engine.currentChatId);
        const messages = await appDb.getMessages(engine.currentChatId);
        if (messages.length === 0) {
            ui.showError('Archive is empty.');
            return;
        }
        messages.sort((a, b) => a.archiveOrder - b.archiveOrder);
        try {
            await navigator.clipboard.writeText(buildTextExportContent(chat, messages));
            const originalText = buttonEl.innerText;
            const originalBg = buttonEl.style.background;
            buttonEl.innerText = 'Copied!';
            buttonEl.style.background = '#a6e3a1';
            setTimeout(() => {
                buttonEl.innerText = originalText;
                buttonEl.style.background = originalBg;
            }, 1800);
        } catch (e) {
            ui.showError('Failed to copy text.');
        }
    }

    function downloadBlob(blob, filename) {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    class PlatformAdapter {
        detect() { return false; }
        getChatId() { return null; }
        getObserverTarget() { return null; }
        getScrollContainer() { return null; }
        extractL1() { return []; }
        extractL2() { return []; }
        extractL3FromMutations() { return []; }
        cleanText(text) { return text; }
        healthCheck() { return false; }
        getCapabilities() {
            return {
                supportsVariants: false,
                supportsReliableStreamingDetection: false,
                supportsDeepScan: false,
                supportsStableRoleDetection: false
            };
        }
        getTempId(firstUserMessage = null) {
            const base = location.hostname + location.pathname;
            return firstUserMessage ? base + firstUserMessage : base + document.title;
        }
    }

    class ChatGPTAdapter extends PlatformAdapter {
        detect() {
            return location.hostname.includes('chatgpt.com');
        }

        getChatId() {
            const match = location.pathname.match(/\/c\/([a-zA-Z0-9-]+)/);
            return match ? match[1] : null;
        }

        getObserverTarget() {
            return document.querySelector('main .flex-1.overflow-hidden')
                || document.querySelector('main [class*="overflow-hidden"]')
                || document.querySelector('main')
                || document.querySelector('[role="main"]')
                || document.body;
        }

        getScrollContainer() {
            const msgs = document.querySelectorAll('[data-testid^="conversation-turn-"], [data-message-author-role]');
            if (msgs.length > 0) {
                let curr = msgs[msgs.length - 1].parentElement;
                while (curr && curr !== document.body && curr !== document.documentElement) {
                    const style = window.getComputedStyle(curr);
                    if (style.overflowY === 'auto' || style.overflowY === 'scroll') {
                        return curr;
                    }
                    curr = curr.parentElement;
                }
            }
            return document.querySelector('main [class*="overflow-y-auto"]')
                || document.querySelector('[class*="react-scroll-to-bottom"]')
                || document.scrollingElement
                || document.documentElement;
        }

        healthCheck() {
            const target = this.getObserverTarget();
            const hasL1 = !!document.querySelector('[data-message-author-role]');
            const hasL2 = !!document.querySelector('[data-testid^="conversation-turn-"], div.text-base, article');
            return !!target && (hasL1 || hasL2);
        }

        getCapabilities() {
            return {
                supportsVariants: true,
                supportsReliableStreamingDetection: true,
                supportsDeepScan: true,
                supportsStableRoleDetection: true
            };
        }

        normalizeRole(role) {
            if (!role) return null;
            const lower = String(role).toLowerCase();
            if (lower.includes('assistant') || lower.includes('chatgpt')) return 'ASSISTANT';
            if (lower.includes('user') || lower.includes('you')) return 'USER';
            if (lower.includes('system')) return 'SYSTEM';
            return null;
        }

        detectRoleFromTurn(turnEl) {
            if (!turnEl) return null;
            const direct = turnEl.getAttribute && this.normalizeRole(turnEl.getAttribute('data-message-author-role'));
            if (direct) return direct;

            const nestedRole = turnEl.querySelector && turnEl.querySelector('[data-message-author-role]');
            if (nestedRole) {
                const nested = this.normalizeRole(nestedRole.getAttribute('data-message-author-role'));
                if (nested) return nested;
            }

            if (turnEl.querySelector && turnEl.querySelector('[aria-label*="Edit message"], [data-testid*="edit"]')) return 'USER';
            if (turnEl.querySelector && turnEl.querySelector('[aria-label*="Copy"], [aria-label*="Read aloud"], [aria-label*="Regenerate"]')) return 'ASSISTANT';

            const rawText = (turnEl.innerText || turnEl.textContent || '').trim();
            if (/^You\b/i.test(rawText)) return 'USER';
            if (/^ChatGPT\b/i.test(rawText)) return 'ASSISTANT';
            return null;
        }

        getConversationRoots() {
            const roots = [];
            const seen = new Set();
            const add = (node) => {
                if (!node || seen.has(node)) return;
                seen.add(node);
                roots.push(node);
            };

            document.querySelectorAll('[data-message-author-role]').forEach(add);
            document.querySelectorAll('[data-testid^="conversation-turn-"]').forEach((turn) => {
                const inner = turn.querySelector('[data-message-author-role]');
                add(inner || turn);
            });
            return roots;
        }

        buildMessage(root, fallbackSignature = '') {
            if (!root) return null;
            const role = this.detectRoleFromTurn(root);
            if (!role || role === 'SYSTEM') return null;
            const text = this.cleanText(Utils.normalizeText(root));
            if (!text) return null;
            const nodeSignature = root.getAttribute('data-message-id')
                || root.getAttribute('data-testid')
                || root.id
                || fallbackSignature
                || root.className
                || `${role}:${text.slice(0, 80)}`;
            return { node: root, role, text, nodeSignature };
        }

        extractL1() {
            return this.getConversationRoots()
                .map((root, idx) => this.buildMessage(root, `chatgpt-l1-${idx}`))
                .filter(Boolean);
        }

        extractL2() {
            const roots = [];
            const seen = new Set();
            const candidates = document.querySelectorAll('[data-testid^="conversation-turn-"], div.text-base, article');
            candidates.forEach((node) => {
                let root = node;
                const nested = node.querySelector && node.querySelector('[data-message-author-role]');
                if (nested) root = nested;
                if (!seen.has(root)) {
                    seen.add(root);
                    roots.push(root);
                }
            });
            return roots.map((root, idx) => this.buildMessage(root, `chatgpt-l2-${idx}`)).filter(Boolean);
        }

        collectCandidateRoots(node, outSet) {
            if (!node) return;
            const el = node.nodeType === Node.TEXT_NODE ? node.parentElement : node;
            if (!el || el.nodeType !== Node.ELEMENT_NODE) return;

            const direct = el.closest('[data-message-author-role]');
            if (direct) outSet.add(direct);

            const turn = el.closest('[data-testid^="conversation-turn-"]');
            if (turn) {
                const inner = turn.querySelector('[data-message-author-role]');
                outSet.add(inner || turn);
            }

            if (el.matches && el.matches('[data-message-author-role], [data-testid^="conversation-turn-"]')) {
                if (el.matches('[data-message-author-role]')) outSet.add(el);
                else {
                    const inner = el.querySelector('[data-message-author-role]');
                    outSet.add(inner || el);
                }
            }

            if (el.querySelector) {
                el.querySelectorAll('[data-message-author-role]').forEach((n) => outSet.add(n));
                el.querySelectorAll('[data-testid^="conversation-turn-"]').forEach((n) => {
                    const inner = n.querySelector('[data-message-author-role]');
                    outSet.add(inner || n);
                });
            }
        }

        extractL3FromMutations(mutations) {
            const candidates = new Set();
            mutations.forEach((m) => {
                if (m.type === 'characterData') {
                    this.collectCandidateRoots(m.target, candidates);
                }
                if (m.type === 'childList') {
                    this.collectCandidateRoots(m.target, candidates);
                    m.addedNodes.forEach((node) => this.collectCandidateRoots(node, candidates));
                }
            });
            const updates = [];
            candidates.forEach((root, idx) => {
                const msg = this.buildMessage(root, `chatgpt-l3-${idx}`);
                if (msg) updates.push(msg);
            });
            return updates;
        }

        cleanText(text) {
            if (!text) return text;
            return text
                .replace(/^You\n?/g, '')
                .replace(/^ChatGPT\n?/g, '')
                .replace(/\n?Copied!$/g, '')
                .replace(/\n?Copy code$/g, '')
                .replace(/\n\d+\/\d+\n/g, '\n')
                .trim();
        }
    }

    class GeminiAdapter extends PlatformAdapter {
        detect() {
            return location.hostname.includes('gemini.google.com');
        }

        getChatId() {
            const match = location.pathname.match(/\/app\/([a-zA-Z0-9]+)/);
            return match ? match[1] : null;
        }

        getObserverTarget() {
            return document.querySelector('message-list')
                || document.querySelector('.conversation-container')
                || document.querySelector('main')
                || document.querySelector('[role="main"]')
                || document.body;
        }

        getScrollContainer() {
            const msgs = document.querySelectorAll('user-message, response-message, message-content, model-response, user-query');
            if (msgs.length > 0) {
                let curr = msgs[msgs.length - 1].parentElement;
                while (curr && curr !== document.body && curr !== document.documentElement) {
                    const style = window.getComputedStyle(curr);
                    if (style.overflowY === 'auto' || style.overflowY === 'scroll') {
                        return curr;
                    }
                    curr = curr.parentElement;
                }
            }
            return document.querySelector('.conversation-container')
                || document.querySelector('message-list')
                || document.querySelector('main [class*="scroll"]')
                || document.scrollingElement
                || document.documentElement;
        }

        healthCheck() {
            const target = this.getObserverTarget();
            const hasL1 = !!document.querySelector('user-message, response-message, message-content, model-response, user-query');
            const hasL2 = !!document.querySelector('.message-content, .model-response-text, [data-test-id*="message"], chat-message');
            return !!target && (hasL1 || hasL2);
        }

        getCapabilities() {
            const hasStableSemantics = !!document.querySelector('user-message, response-message');
            return {
                supportsVariants: true,
                supportsReliableStreamingDetection: true,
                supportsDeepScan: true,
                supportsStableRoleDetection: hasStableSemantics
            };
        }

        extractL1() {
            const messages = [];
            document.querySelectorAll('user-message, response-message, message-content').forEach((el, index) => {
                const text = this.cleanText(Utils.normalizeText(el));
                if (!text) return;
                let role = 'RAW';
                if (el.tagName.toLowerCase() === 'user-message') role = 'USER';
                else if (el.tagName.toLowerCase() === 'response-message') role = 'ASSISTANT';
                else role = index % 2 === 0 ? 'USER' : 'ASSISTANT';
                messages.push({ node: el, role, text, nodeSignature: el.id || `gemini-msg-${index}` });
            });
            return messages;
        }

        extractL2() {
            const messages = [];
            document.querySelectorAll('.message-content, .model-response-text').forEach((el, index) => {
                const text = this.cleanText(Utils.normalizeText(el));
                if (!text) return;
                const isUser = !el.classList.contains('model-response-text');
                messages.push({ node: el, role: isUser ? 'USER' : 'ASSISTANT', text, nodeSignature: `gemini-l2-${index}` });
            });
            return messages;
        }

        extractL3FromMutations(mutations) {
            const updates = [];
            mutations.forEach((m) => {
                if (m.type !== 'characterData' && m.type !== 'childList') return;
                const target = m.target.nodeType === Node.TEXT_NODE ? m.target.parentElement : m.target;
                const assistantEl = target && target.closest ? target.closest('response-message, .model-response-text') : null;
                if (assistantEl) {
                    updates.push({
                        node: assistantEl,
                        role: 'ASSISTANT',
                        text: this.cleanText(Utils.normalizeText(assistantEl)),
                        nodeSignature: assistantEl.id || 'gemini-streaming'
                    });
                }
            });
            return updates;
        }

        cleanText(text) {
            if (!text) return text;
            return text
                .replace(/Show drafts\n?/g, '')
                .replace(/Good response\n?/g, '')
                .replace(/Bad response\n?/g, '')
                .replace(/Modify response\n?/g, '')
                .replace(/Share and export\n?/g, '')
                .trim();
        }
    }

    const bootstrap = async () => {
        const engine = new Engine(appDb);
        const ui = new FloatingUI(
            engine,
            () => performExport(engine, ui),
            () => performMarkdownExport(engine, ui),
            () => performJsonExport(engine, ui),
            () => performPartExport(engine, ui),
            (btn) => performCopyAll(engine, ui, btn)
        );
        ui.init();

        try {
            await appDb.init();
            const routeWatcher = new RouteWatcher(engine);
            routeWatcher.start();
        } catch (e) {
            console.error('[Chronicler] DB Error:', e);
            engine.hasFatalDbError = true;
            engine.onStateChange('DB ERROR', `IndexedDB Error: ${e.message || 'Init Failed'}`);
        }
    };

    bootstrap();
